HOST=127.0.0.1
PORT=7676

# Owner password is generated by `loom init` and stored in ~/.loom/auth.json.
# LOOM_OAUTH_OWNER_TOKEN=change-me-to-a-long-random-secret
LOOM_ALLOWED_ROOTS=/Users/you/projects

# Public HTTPS origin only; MCP clients connect to this origin plus /mcp.
# LOOM_PUBLIC_BASE_URL=https://loom.example.com
# LOOM_ALLOWED_HOSTS=localhost,127.0.0.1,loom.example.com

# Optional OAuth and logging controls.
# LOOM_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
# LOOM_OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
# LOOM_OAUTH_SCOPES=loom
# LOOM_OAUTH_ALLOWED_REDIRECT_HOSTS=chatgpt.com,localhost,127.0.0.1
LOOM_LOG_LEVEL=info
LOOM_LOG_FORMAT=json
LOOM_LOG_REQUESTS=1
LOOM_LOG_TOOL_CALLS=1
